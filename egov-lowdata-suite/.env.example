### 기본 환경변수 (로컬 모드)
# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_DB=egov

# ODK Central
ODK_BASE_URL=http://odk
# Session bearer token from POST /v1/sessions (24h validity)
ODK_API_TOKEN=
# App User token for /v1/key/<token>/... requests (optional)
ODK_APP_USER_TOKEN=
# Host header to send when calling ODK (leave blank to skip)
ODK_HOST_HEADER=
ODK_EXTERNAL_URL=http://localhost:8383

# Metabase
MB_BASE_URL=http://metabase:3000
MB_EMBED_SECRET=dev-embed-secret
MB_EMBED_ENABLED=false
MB_SESSION=
MB_DATABASE_ID=1
MB_METADATA_DB=metabase

# XLSForm Sidecar
SIDECAR_BASE=http://sidecar:5001

# K-eGov (optional)
KEGOV_API_URL=http://localhost:9000
KEGOV_API_KEY=

# Security
SECRET_KEY=supersecret

# DBT
DBT_PROFILES_DIR=/app/etl
DBT_PROJECT_DIR=/app/etl

# Spring Boot
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default
